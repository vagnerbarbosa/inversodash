# Inversor Goodwe - CONFIGURE O IP DO SEU INVERSOR
INVERTER_IP=<SEU_IP_AQUI>
INVERTER_PORT=502

# InfluxDB - CONFIGURAR SENHAS SEGURAS AQUI
INFLUXDB_DB=inversodash
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme_gerar_senha_segura
INFLUXDB_TOKEN=admin:changeme_gerar_senha_segura
INFLUXDB_ORG=inversodash
INFLUXDB_BUCKET=inversodash

CUSTO_INSTALACAO=35000
DATA_INSTALACAO=2024-03-15

# Nota: Para gerar um token seguro, use:
# openssl rand -base64 32
